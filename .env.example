VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: hosted Sanity Studio URL for Portal links (defaults in src/config/externalLinks.js).
# VITE_SANITY_STUDIO_URL=https://www.sanity.io/@oGxctQ0AW/studio/lcsp3cr8syu9em899qg7e2gb/default/structure

# Optional: set to "true" to read from Sanity’s CDN (faster, may briefly lag after Publish).
# Omit or leave false so the live API is used and new publishes appear on the site right away.
# VITE_SANITY_USE_CDN=true

# Debug: minimal GROQ slice (see src/lib/sanityQueries.js). Omit for full listing query.
# VITE_SANITY_MINIMAL_QUERY=true
