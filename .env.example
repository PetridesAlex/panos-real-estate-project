VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: hosted Sanity Studio URL for Portal links.
# VITE_SANITY_STUDIO_URL=https://unitedproperties-eu.sanity.studio/

# Optional: WhatsApp / Telegram chat links (navbar + footer). Defaults in src/config/externalLinks.js.
# VITE_WHATSAPP_URL=https://wa.me/35700000000
# VITE_TELEGRAM_URL=https://t.me/yourhandle

# Optional: tel: link for phone icon in quick-contact FAB (defaults in src/config/externalLinks.js).
# VITE_CONTACT_PHONE_TEL=tel:+35725123456

# Optional: set to "true" to read from Sanity’s CDN (faster, may briefly lag after Publish).
# Omit or leave false so the live API is used and new publishes appear on the site right away.
# VITE_SANITY_USE_CDN=true

# Debug: minimal GROQ slice (see src/lib/sanityQueries.js). Omit for full listing query.
# VITE_SANITY_MINIMAL_QUERY=true

# Optional: Sanity read token for scripts/generate-sitemap.js if your dataset requires auth for GROQ at build time.
# SANITY_API_READ_TOKEN=

# Required for server-side /api/inquiries endpoint (Vercel/Node runtime only, never expose in client):
# SANITY_API_WRITE_TOKEN=
# Optional overrides for server endpoint defaults:
# SANITY_PROJECT_ID=d7j11dpu
# SANITY_DATASET=production
# SANITY_API_VERSION=2024-01-01

# Local dev: contact form POST goes to deployed /api/inquiries (defaults to unitedproperties.eu).
# Override if needed:
# VITE_INQUIRY_API_URL=https://www.unitedproperties.eu
