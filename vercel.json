{
  "redirects": [
    {
      "source": "/new-developments",
      "destination": "/properties",
      "permanent": true
    },
    {
      "source": "/developments",
      "destination": "/properties",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sanity-api/:path*",
      "destination": "https://d7j11dpu.api.sanity.io/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
